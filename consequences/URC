.steps{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin:30px 0}.step{padding:18px 15px;border-radius:20px;background:#fff;border-top:10px solid var(--red);text-align:center}.step:nth-child(2){border-top-color:var(--blue)}.step:nth-child(3){border-top-color:var(--yellow)}.step:nth-child(4){border-top-color:var(--turquoise)}.step:nth-child(5){border-top-color:var(--red)}.step b{display:block;font-size:32px;margin-bottom:8px}.cta{margin-top:28px;border-radius:30px;padding:32px;background:var(--red);color:#fff;text-align:center}.cta h2{font-size:42px;line-height:1;text-transform:uppercase;margin-bottom:14px}.cta p{font-size:22px;margin-bottom:10px}.deadline{display:inline-block;margin-top:10px;padding:12px 18px;border-radius:999px;background:var(--yellow);color:#222;font-size:22px;font-weight:900}.footer-line{position:absolute;left:0;right:0;bottom:0;height:18px;background:linear-gradient(90deg,var(--red) 0 25%,var(--yellow) 25% 50%,var(--blue) 50% 75%,var(--turquoise) 75%)}
@media(max-width:820px){.page{padding:28px 22px;min-height:auto}.hero-title{font-size:48px}.hero-sub{font-size:22px}.objective-box,.grid-2{grid-template-columns:1fr}.commissions{grid-template-columns:repeat(2,1fr)}.steps{grid-template-columns:1fr}.flow .sectors{grid-template-columns:1fr}.flow .ce{margin:0}.rules ul{columns:1}}
