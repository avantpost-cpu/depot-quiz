.objective-box{margin-top:42px;display:grid;grid-template-columns:1.1fr .9fr;gap:28px;align-items:stretch}.card{border-radius:28px;padding:30px}.card.red{background:var(--red);color:#fff}.card.blue{background:var(--blue);color:#fff}.card.yellow{background:var(--yellow)}.card.turquoise{background:var(--turquoise)}.card h2{margin-bottom:16px;font-size:35px;line-height:1;text-transform:uppercase}.big-list{margin:0;padding-left:22px;font-size:21px}.big-list li{margin:8px 0}.quote{font-size:31px;font-weight:800;line-height:1.15}.page-num{position:absolute;right:30px;bottom:22px;font-size:14px;font-weight:800;opacity:.55}.section-title{color:var(--red);font-size:52px;line-height:.95;font-weight:900;text-transform:uppercase;margin-bottom:28px}
.flow{display:grid;gap:0;max-width:900px;margin:10px auto 26px}.flow .level{border-radius:26px;padding:24px 28px;color:#fff;text-align:center;font-weight:900;font-size:28px;text-transform:uppercase}.flow .ag{background:var(--blue)}.flow .ce{background:var(--yellow);color:#222;margin:0 60px}.flow .sectors{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.flow .sector{background:var(--blue);border-radius:20px;padding:24px 16px;color:#fff;text-align:center;font-weight:900;font-size:22px}.connector{height:34px;position:relative}.connector:before{content:"";position:absolute;left:50%;top:0;width:5px;height:34px;background:var(--yellow);transform:translateX(-50%)}.note{margin-top:20px;border-left:8px solid var(--yellow);padding:18px 22px;background:#fff;font-size:20px}.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:24px}
